# Files in the repo root that must NOT be published as public assets.
# (gitignore-style syntax). _headers / _redirects are consumed by the
# assets runtime, not served, so they are intentionally kept.
wrangler.jsonc
.gitignore
*.md

# Dev/VCS dirs that must never be served as public assets.
.git
.git/**
.wrangler
.wrangler/**
node_modules
.assetsignore

# Local Claude Code session/scheduling artifacts — never serve these.
.claude
.claude/**
